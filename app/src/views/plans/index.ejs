<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">My Plans</h2>
  <a href="/plans/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Plan</a>
</div>

<% if (plans.length === 0) { %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-folder text-muted" style="font-size: 3rem;"></i>
      <p class="text-muted mt-3 mb-3">No plans yet. Create one to get started!</p>
      <a href="/plans/new" class="btn btn-primary">Create Your First Plan</a>
    </div>
  </div>
<% } else { %>
  <div class="row g-3">
    <% plans.forEach(function(plan) { %>
      <div class="col-12">
        <div class="card">
          <div class="card-body d-flex justify-content-between align-items-start">
            <div>
              <h5 class="mb-1">
                <i class="bi bi-folder me-1 text-primary"></i>
                <a href="/plans/<%= plan.id %>" class="text-decoration-none"><%= plan.title %></a>
              </h5>
              <% if (plan.task_count !== undefined) { %>
                <span class="small text-muted"><%= plan.task_count %> task<%= plan.task_count !== 1 ? 's' : '' %></span>
              <% } %>
              <% if (plan.description) { %>
                <p class="text-muted mb-1 small"><%= plan.description %></p>
              <% } %>
              <div class="small text-muted">Created <%= plan.created_at %></div>
            </div>
            <div class="d-flex align-items-center gap-2">
              <a href="/plans/<%= plan.id %>" class="btn btn-sm btn-outline-primary">View Tasks &rarr;</a>
              <form action="/plans/<%= plan.id %>/delete" method="POST" onsubmit="return confirm('Delete this plan and all its tasks?');">
                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>
