<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">My Tasks</h2>
  <a href="/tasks/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Task</a>
</div>

<!-- Filters -->
<div class="card mb-4">
  <div class="card-body">
    <h6 class="card-title mb-3">Filters &amp; Sorting</h6>
    <form action="/tasks" method="GET" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label for="status" class="form-label small">Status</label>
        <select class="form-select form-select-sm" id="status" name="status">
          <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All Statuses</option>
          <option value="not_started" <%= filters.status === 'not_started' ? 'selected' : '' %>>Not Started</option>
          <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
          <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
        </select>
      </div>
      <div class="col-md-3">
        <label for="category" class="form-label small">Category</label>
        <select class="form-select form-select-sm" id="category" name="category">
          <option value="all" <%= filters.category === 'all' ? 'selected' : '' %>>All Categories</option>
          <% categories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }); %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="sort" class="form-label small">Sort By</label>
        <select class="form-select form-select-sm" id="sort" name="sort">
          <option value="due_date" <%= filters.sort === 'due_date' ? 'selected' : '' %>>Due Date</option>
          <option value="status" <%= filters.sort === 'status' ? 'selected' : '' %>>Status</option>
          <option value="created" <%= filters.sort === 'created' ? 'selected' : '' %>>Created</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-sm btn-outline-primary w-100">Apply</button>
      </div>
    </form>
  </div>
</div>

<!-- Task list -->
<% if (tasks.length === 0) { %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-check2-all text-muted" style="font-size: 3rem;"></i>
      <p class="text-muted mt-3 mb-3">No tasks found. Create one to get started!</p>
      <a href="/tasks/new" class="btn btn-primary">Create Your First Task</a>
    </div>
  </div>
<% } else { %>
  <% tasks.forEach(function(task) { %>
    <%
      var isOverdue = false;
      if (task.due_date && task.status !== 'completed') {
        var due = new Date(task.due_date + 'T00:00:00');
        var now = new Date();
        now.setHours(0,0,0,0);
        isOverdue = due < now;
      }
    %>
    <div class="card mb-2 <%= isOverdue ? 'border-danger' : '' %>">
      <div class="card-body d-flex justify-content-between align-items-center py-2">
        <div>
          <a href="/tasks/<%= task.id %>" class="fw-semibold text-decoration-none"><%= task.title %></a>
          <div class="small">
            <span class="badge bg-<%= task.status === 'in_progress' ? 'primary' : (task.status === 'completed' ? 'success' : 'secondary') %>">
              <%= task.status === 'not_started' ? 'Not Started' : (task.status === 'in_progress' ? 'In Progress' : 'Completed') %>
            </span>
            <% if (task.category) { %>
              <span class="text-muted ms-1"><i class="bi bi-tag me-1"></i><%= task.category %></span>
            <% } %>
            <% if (task.plan_title) { %>
              <span class="text-muted ms-1"><i class="bi bi-folder me-1"></i><%= task.plan_title %></span>
            <% } %>
          </div>
          <% if (task.notes) { %>
            <div class="small text-muted mt-1"><%= task.notes.length > 80 ? task.notes.substring(0, 80) + '...' : task.notes %></div>
          <% } %>
        </div>
        <div class="d-flex align-items-center gap-2">
          <% if (task.due_date) { %>
            <span class="small <%= isOverdue ? 'text-danger fw-semibold' : 'text-muted' %>">
              <i class="bi bi-calendar me-1"></i><%= task.due_date %>
              <% if (isOverdue) { %><span class="badge bg-danger ms-1">Overdue</span><% } %>
            </span>
          <% } %>
          <div class="d-flex gap-1">
            <a href="/tasks/<%= task.id %>" class="btn btn-sm btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>
            <% if (task.status !== 'in_progress') { %>
              <form action="/tasks/<%= task.id %>/status" method="POST" class="d-inline">
                <input type="hidden" name="status" value="in_progress">
                <button type="submit" class="btn btn-sm btn-outline-warning" title="Start"><i class="bi bi-play-fill"></i></button>
              </form>
            <% } %>
            <% if (task.status !== 'completed') { %>
              <form action="/tasks/<%= task.id %>/status" method="POST" class="d-inline">
                <input type="hidden" name="status" value="completed">
                <button type="submit" class="btn btn-sm btn-outline-success" title="Complete"><i class="bi bi-check-lg"></i></button>
              </form>
            <% } %>
            <form action="/tasks/<%= task.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this task?');">
              <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% }); %>
<% } %>
